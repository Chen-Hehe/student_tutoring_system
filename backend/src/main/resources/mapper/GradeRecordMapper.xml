<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tutoring.repository.GradeRecordRepository">
    <resultMap id="GradeRecordResultMap" type="com.tutoring.entity.GradeRecord">
        <id column="id" property="id" />
        <result column="report_id" property="reportId" />
        <result column="subject" property="subject" />
        <result column="grade" property="grade" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
        <result column="deleted" property="deleted" />
    </resultMap>

    <!-- 根据报告ID查询成绩记录 -->
    <select id="findByReportId" resultMap="GradeRecordResultMap">
        SELECT * FROM grade_records
        WHERE report_id = #{reportId}
        AND deleted = 0
        ORDER BY subject
    </select>

</mapper>
