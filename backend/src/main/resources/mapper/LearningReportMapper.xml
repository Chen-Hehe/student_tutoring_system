<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tutoring.repository.LearningReportRepository">
    <resultMap id="LearningReportResultMap" type="com.tutoring.entity.LearningReport">
        <id column="id" property="id" />
        <result column="student_id" property="studentId" />
        <result column="report_period" property="reportPeriod" />
        <result column="overall" property="overall" />
        <result column="class_rank" property="classRank" />
        <result column="comment" property="comment" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
        <result column="deleted" property="deleted" />
    </resultMap>

    <!-- 根据学生ID查询学习报告 -->
    <select id="findByStudentId" resultMap="LearningReportResultMap">
        SELECT * FROM learning_reports
        WHERE student_id = #{studentId}
        AND deleted = 0
        ORDER BY created_at DESC
    </select>

</mapper>
