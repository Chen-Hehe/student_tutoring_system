# 服务器端口
PORT=3000

# MongoDB 连接字符串
MONGODB_URI=mongodb://localhost:27017/rural-education-platform

# JWT 密钥 (生产环境请修改为随机字符串)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT 过期时间
JWT_EXPIRE=7d

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Socket.IO 配置
CORS_ORIGIN=http://localhost:5173
